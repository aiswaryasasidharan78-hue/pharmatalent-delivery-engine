# ─── Apify ────────────────────────────────────────────────────────────────────
APIFY_TOKEN=

# ─── People Search ────────────────────────────────────────────────────────────
# AI Ark (primary). Sign up: https://aiark.com
AI_ARK_TOKEN=

# Prospeo.io (accepted alternative / fallback). Sign up: https://prospeo.io
# Required if you use Prospeo instead of (or alongside) AI Ark.
PROSPEO_API_KEY=

# ─── OpenRouter ───────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional – direct Postgres connection string (psycopg / asyncpg / SQLAlchemy)
# SUPABASE_DB_URL=

# ─── Pipeline settings ────────────────────────────────────────────────────────
MAX_SCRAPE_ITEMS=500
PEOPLE_SEARCH_PROVIDER=prospeo
ICP_MODEL=openai/gpt-4o-mini
HM_VALIDATION_MODEL=openai/gpt-4o-mini
LOG_LEVEL=INFO
